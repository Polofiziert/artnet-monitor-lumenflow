# LumenFlow Development Environment

# Copy Rust configuration
COPY .cargo-config.toml ~/.cargo/config.toml

# Set Rust backtrace for better debugging
export RUST_BACKTRACE=1

# Enable debug logging by default in development
export RUST_LOG=lumenflow_core=debug,lumenflow_ui=debug

# Unicast discovery targets for Docker virtual network testing.
# When set, LumenFlow sends ArtPoll to these addresses in addition to broadcast.
# Use with: docker compose -f docker-compose.virtual-network.yml up
# export LUMENFLOW_DISCOVERY_TARGETS=127.0.0.1:6455,127.0.0.1:6456,127.0.0.1:6457

# Ensure pnpm uses proper node_modules management
export PNPM_HOME="$HOME/.pnpm"
