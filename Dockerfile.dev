FROM rust:latest

RUN apt-get update && apt-get install -y \
    build-essential \
    clang \
    libssl-dev \
    pkg-config \
    curl \
    && curl -fsSL https://deb.nodesource.com/setup_18.x | bash - \
    && apt-get install -y nodejs \
    && npm install -g pnpm \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
