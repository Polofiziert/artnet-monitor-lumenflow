{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LumenFlow",
  "version": "0.2.0",
  "identifier": "dev.lumenflow.app",
  "build": {
    "beforeBuildCommand": "pnpm run build:ui",
    "beforeDevCommand": "pnpm run dev:ui",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../../dist",
    "features": []
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 900,
        "resizable": true,
        "title": "LumenFlow - Art-Net Monitor",
        "width": 1600,
        "minHeight": 600,
        "minWidth": 1000
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
