{
  "name": "lumenflow",
  "version": "0.2.0",
  "description": "Professional Art-Net 4 monitoring and control software",
  "private": true,
  "license": "GPL-3.0-or-later OR MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "dev": "tauri dev",
    "dev:docker": "bash -c 'set -a && [ -f scripts/virtual-network.ports.env ] && . scripts/virtual-network.ports.env; set +a && export LUMENFLOW_DISCOVERY_TARGETS=\"${VIRTUAL_NETWORK_DISCOVERY_TARGETS:-127.0.0.1:6455,127.0.0.1:6456,127.0.0.1:6457}\" && exec tauri dev'",
    "dev:fresh": "pnpm clean && pnpm run dev",
    "build": "tauri build",
    "build:ui": "vite build",
    "build:rust": "cargo build --release -p lumenflow_core -p lumenflow_ui",
    "dev:ui": "vite",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx --fix && cargo clippy --all-targets --all-features -- -D warnings",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "cargo test --test '*' --features integration-tests",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed",
    "test:ui:debug": "playwright test --debug",
    "test:ui:update": "playwright test --update-snapshots",
    "test:chaos": "cargo test --test '*' --release",
    "test:fuzz": "cargo fuzz run artnet_dmx_parser",
    "test:wireshark": "./scripts/wireshark-compliance-test.sh",
    "test:all": "cargo test --all && pnpm test && pnpm test:ui",
    "coverage": "vitest run --coverage",
    "format": "prettier --write . && cargo fmt --all",
    "format:check": "prettier --check . && cargo fmt --all -- --check",
    "clean": "rm -rf dist target && cargo clean && rm -rf test-results",
    "setup": "bash scripts/setup.sh",
    "perf:profile": "tauri build --debug && time ./src-tauri/target/debug/lumenflow",
    "perf:bench": "cargo bench --all",
    "docs": "cargo doc --no-deps --document-private-items && npm run docs:ui",
    "docs:ui": "typedoc"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-window-state": "^2.0.0",
    "solid-js": "^1.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^8.52.0",
    "@playwright/test": "^1.40.0",
    "@solidjs/router": "^0.15.4",
    "@solidjs/testing-library": "^0.8.10",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/dom": "^9.3.0",
    "@types/node": "^20.9.0",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vitest/coverage-v8": "^1.0.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.52.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.31",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.3.0",
    "typedoc": "^0.25.0",
    "typescript": "^5.2.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^5.0.0",
    "vite-plugin-solid": "^2.11.11",
    "vitest": "^0.34.0"
  }
}
